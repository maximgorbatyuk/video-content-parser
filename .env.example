# Absolute path to the folder with source video files.
# `~` is expanded to your home directory.
SOURCE_FOLDER=~/photo-projects/istanbul/video

# Output folder for result JSON files. Relative to the directory you run
# analyze_videos.py from (so `results` -> `<cwd>/results`).
OUTPUT_FOLDER=results

# Base URL of your locally deployed vision LLM
# (llama-server, LM Studio, etc. — anything OpenAI-compatible).
LLM_URL=http://127.0.0.1:1234

# --- Optional tuning knobs (sensible defaults shown) ---
# FRAMES=8
# MAX_SIDE=448
# TIMEOUT=600
# TEMPERATURE=0.1
# MAX_TOKENS=1024
# DISABLE_THINKING=1
